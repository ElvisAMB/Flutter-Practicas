<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ══════════════════════════════════════════════════════════
         PERMISOS DE UBICACIÓN (iOS)
         El texto que el usuario verá en el diálogo de permiso.
         Sé específico y claro sobre el motivo del uso.
    ══════════════════════════════════════════════════════════ -->

    <!-- Ubicación solo mientras la app está en primer plano -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>GeoMaps necesita acceso a tu ubicación para mostrar tu posición en el mapa y proporcionar información sobre tu entorno.</string>

    <!-- Ubicación siempre (también en segundo plano) -->
    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>GeoMaps necesita acceso continuo a tu ubicación para el seguimiento en tiempo real, incluso cuando la aplicación está en segundo plano.</string>

    <!-- iOS 11 y anteriores -->
    <key>NSLocationAlwaysUsageDescription</key>
    <string>GeoMaps necesita acceso a tu ubicación para el seguimiento en tiempo real.</string>

    <!-- ══════════════════════════════════════════════════════════
         CONFIGURACIÓN GENERAL
    ══════════════════════════════════════════════════════════ -->
    <key>CFBundleDevelopmentRegion</key>
    <string>es</string>

    <key>CFBundleDisplayName</key>
    <string>GeoMaps</string>

    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>

    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>GeoMaps</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleShortVersionString</key>
    <string>$(FLUTTER_BUILD_NAME)</string>

    <key>CFBundleSignature</key>
    <string>????</string>

    <key>CFBundleVersion</key>
    <string>$(FLUTTER_BUILD_NUMBER)</string>

    <key>LSRequiresIPhoneOS</key>
    <true/>

    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

    <key>UIMainStoryboardFile</key>
    <string>Main</string>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
</dict>
</plist>
